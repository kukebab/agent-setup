#!/usr/bin/env bash
# pre-commit guard for agent-os projects.
#
# - HARD-BLOCKS staged files containing obvious PII patterns (configurable below)
# - HARD-BLOCKS staleness drift on current-state files (agent/memory/STATE.md,
#   agent/memory/clients/*.md, agent/agents/*/PROJECT_MAP.md) via check-staleness.py
#
# Activate once per checkout:
#   git config core.hooksPath agent/scripts/git-hooks
#
# Overrides:
#   git commit --no-verify           # nuclear, skips everything
#   STALENESS_SKIP=1 git commit ...  # only skips staleness, PII still enforced

set -e

staged=$(git diff --cached --name-only --diff-filter=AM)
[ -z "$staged" ] && exit 0

# ── Hard block — PII paths (CUSTOMIZE FOR YOUR PROJECT) ───────────
# Add patterns here for paths that should NEVER enter git (real customer data,
# credentials, raw documents with PII, etc.)
#
# Examples:
#   '^secrets/'
#   '\.env\.'
#   '^clients/.+\.pdf$'
#
# Default: empty (no PII patterns enforced). Customize before relying on it.
pii_pattern=''

if [ -n "$pii_pattern" ]; then
  pii_hits=$(echo "$staged" | grep -E "$pii_pattern" || true)
  if [ -n "$pii_hits" ]; then
    echo ""
    echo "🛑 BLOCKED — PII paths detected in commit:"
    echo "$pii_hits" | sed 's/^/    /'
    echo ""
    echo "These files match the configured PII pattern and must NOT enter git."
    echo "Move them outside the repo or rename outside the blocked patterns."
    echo ""
    exit 1
  fi
fi

# ── Hard block — staleness drift on current-state files ─────────
python3 "$(dirname "$0")/check-staleness.py" || exit 1

exit 0
